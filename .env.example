# ─── Supabase ───────────────────────────────────────────────────────────────
# Local dev (supabase start): http://localhost:54321
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Next.js public vars
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ─── API ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Admin Portal ────────────────────────────────────────────────────────────
# Comma-separated admin emails. If empty, any logged-in user can access /admin.
ADMIN_EMAILS=admin@yourdomain.com

# ─── AI Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=

# ─── Queue ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://vidyai:vidyai_dev@localhost:5672/vidyai

# ─── Storage ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vidyai-content-dev
AWS_REGION=ap-south-1

# ─── Billing ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
DATADOG_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
